# ──────────────────────────────────────────
# Copy this file to .env and fill in values
# ──────────────────────────────────────────

# Database (get a free URL at neon.tech)
DATABASE_URL=postgresql://user:pass@host/titra

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# Next.js
NEXTAUTH_SECRET=change-me-to-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email — get a free API key at resend.com
RESEND_API_KEY=

# File uploads — get free credentials at cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# App URLs
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
