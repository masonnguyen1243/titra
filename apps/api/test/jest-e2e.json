{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testRegex": "test/.+\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "tsconfig.e2e.json" }]
  },
  "moduleNameMapper": {
    "^@react-pdf/renderer$": "<rootDir>/test/__mocks__/@react-pdf/renderer.js"
  },
  "testEnvironment": "node",
  "testTimeout": 120000
}
